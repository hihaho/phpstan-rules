{
    "name": "hihaho/phpstan-rules",
    "description": "Hihaho PHPStan rules according to the guidelines",
    "homepage": "https://guidelines.hihaho.com",
    "type": "phpstan-extension",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Hihaho\\PhpstanRules\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hihaho\\PhpstanRules\\Tests\\": "tests/"
        },
        "classmap": [
            "tests/Rules/stubs/",
            "tests/Rules/Debug/stubs/"
        ],
        "exclude-from-classmap": [
            "tests/Rules/stubs/facade-alias-in-view.blade.php"
        ]
    },
    "authors": [
        {
            "name": "hihaho",
            "email": "info@hihaho.com",
            "homepage": "https://www.hihaho.com/",
            "role": "Organisation"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": "^8.3",
        "phpstan/phpstan": "^2.1.8",
        "illuminate/support": "^11.31|^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.21",
        "nikic/php-parser": "^5.4",
        "orchestra/testbench": "^9.0||^10.0||^11.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^11.5",
        "rector/rector": "^2.0",
        "rector/type-perfect": "^2.0",
        "roave/security-advisories": "dev-latest",
        "sandermuller/package-boost": "^0.2",
        "spatie/invade": "^2.1",
        "spaze/phpstan-disallowed-calls": "^4.4",
        "symplify/phpstan-extensions": "^12.0.1",
        "tomasvotruba/cognitive-complexity": "^1.0",
        "tomasvotruba/type-coverage": "^2.0"
    },
    "scripts": {
        "fix-cs": "vendor/bin/pint",
        "format": "vendor/bin/pint",
        "phpstan": "vendor/bin/phpstan analyse --memory-limit=2G",
        "phpstan-clear-cache": "vendor/bin/phpstan clear-result-cache",
        "phpstan-simplified": "vendor/bin/phpstan analyse --memory-limit=2G --error-format symplify",
        "rector": "vendor/bin/rector process",
        "test": "vendor/bin/phpunit",
        "qa": ["@format", "@rector", "@phpstan", "@test"]
    },
    "extra": {
        "phpstan": {
            "includes": [
                "extension.neon"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "phpstan/extension-installer": true
        },
        "sort-packages": true
    }
}
