parametersSchema:
    noUnsafeRequestData: structure([
        unsafeMethods: listOf(string())
        namespaces: listOf(string())
        excludeNamespaces: listOf(string())
    ])
    unvalidatedFormRequestField: structure([
        accessors: listOf(string())
    ])
    positionalFlagArgument: structure([
        firstPartyNamespaces: listOf(string())
    ])

parameters:
    noUnsafeRequestData:
        unsafeMethods:
            - input
            - all
            - get
            - query
            - post
            - only
            - except
            - collect
            - string
            - str
            - integer
            - boolean
            - float
            - json
            - keys
            - fluent
            - array
            - date
            - enum
            - enums
            - file
            - allFiles
        namespaces:
            - App
        excludeNamespaces:
            - App\Providers
            - App\Http\Responses
    unvalidatedFormRequestField:
        accessors:
            - input
            - get
            - query
            - post
            - string
            - str
            - integer
            - boolean
            - float
            - json
            - array
            - collect
            - date
            - enum
            - enums
            - file
    positionalFlagArgument:
        firstPartyNamespaces:
            - App
            - Database\Factories
            - Tests

rules: []

services:
    -
        class: Hihaho\PhpstanRules\Rules\CombinedFuncCallRule
        arguments:
            namespaces: %noUnsafeRequestData.namespaces%
            excludeNamespaces: %noUnsafeRequestData.excludeNamespaces%
            reflectionProvider: @reflectionProvider
        tags:
            - phpstan.rules.rule
    -
        class: Hihaho\PhpstanRules\Rules\CombinedStaticCallRule
        arguments:
            unsafeMethods: %noUnsafeRequestData.unsafeMethods%
            namespaces: %noUnsafeRequestData.namespaces%
            excludeNamespaces: %noUnsafeRequestData.excludeNamespaces%
            firstPartyNamespaces: %positionalFlagArgument.firstPartyNamespaces%
        tags:
            - phpstan.rules.rule
    -
        class: Hihaho\PhpstanRules\Rules\CombinedMethodCallRule
        arguments:
            unsafeMethods: %noUnsafeRequestData.unsafeMethods%
            fieldAccessors: %unvalidatedFormRequestField.accessors%
            namespaces: %noUnsafeRequestData.namespaces%
            excludeNamespaces: %noUnsafeRequestData.excludeNamespaces%
            parser: @defaultAnalysisParser
            firstPartyNamespaces: %positionalFlagArgument.firstPartyNamespaces%
        tags:
            - phpstan.rules.rule
    -
        class: Hihaho\PhpstanRules\Rules\Conventions\PositionalFlagArgumentConstructorRule
        arguments:
            reflectionProvider: @reflectionProvider
            firstPartyNamespaces: %positionalFlagArgument.firstPartyNamespaces%
        tags:
            - phpstan.rules.rule
